{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "PUPPETEER_SKIP_DOWNLOAD=true npm install",
  "framework": "vite",
  "redirects": [
    {
      "source": "/freelance",
      "destination": "/consulting",
      "permanent": true
    },
    {
      "source": "/freelance/:path*",
      "destination": "/consulting/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
